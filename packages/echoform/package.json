{
  "name": "@playfast/echoform",
  "version": "1.0.4",
  "description": "run your react app logic on the server",
  "type": "module",
  "exports": {
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "import": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    },
    ".": {
      "types": "./src/shared/index.ts",
      "import": "./src/shared/index.ts",
      "default": "./src/shared/index.ts"
    },
    "./shared": {
      "types": "./src/shared/index.ts",
      "import": "./src/shared/index.ts",
      "default": "./src/shared/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsgo -p .",
    "build": "tsgo -p .",
    "test": "bun test tests/"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "dependencies": {
    "crypto-random-string": "5.0.0",
    "fossil-delta": "^2.0.0",
    "typed-binary": "^4.3.3"
  },
  "devDependencies": {
    "@playfast/echoform-render": "workspace:*",
    "@types/react": "19.0.2",
    "react": "19.0.0"
  },
  "keywords": [
    "react",
    "express",
    "typescript",
    "http"
  ],
  "author": "shmuelhizmi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/springdotnew/echoform.git"
  },
  "bugs": {
    "url": "https://github.com/springdotnew/echoform/issues"
  },
  "homepage": "https://github.com/springdotnew/echoform/tree/master/packages/echoform#readme"
}
