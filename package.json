{
  "name": "@react-fullstack/root",
  "private": true,
  "packageManager": "bun@1.3.4",
  "version": "1.0.0",
  "repository": "https://github.com/shmuelhizmi/react-fullstack.git",
  "author": "shmuelhizmi <shmuelhizmi1@gmail.com>",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "plugins/*/*",
    "demo/*"
  ],
  "scripts": {
    "typecheck": "tsgo -p packages/fullstack && tsgo -p packages/react-render-null && tsgo -p plugins/fullstack/bun-ws-client && tsgo -p plugins/fullstack/bun-ws-server && tsgo -p plugins/fullstack/socket-client && tsgo -p plugins/fullstack/socket-server",
    "build": "bun run typecheck",
    "clean": "rm -rf packages/*/dist packages/*/lib plugins/*/*/dist plugins/*/*/lib",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:packages": "oxlint packages/",
    "lint:plugins": "oxlint plugins/",
    "knip": "knip",
    "knip:fix": "knip --fix"
  },
  "dependencies": {
    "@changesets/cli": "^2.25.2"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260323.1",
    "knip": "^5.0.0",
    "oxlint": "^0.13.0"
  }
}
