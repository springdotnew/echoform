{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": ["*.{ts,tsx,js,jsx}"]
    },
    "packages/echoform": {
      "entry": [
        "src/shared/index.ts",
        "src/server/index.ts",
        "src/client/index.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/react-render-null": {
      "entry": ["src/render.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "plugins/socket-server": {
      "entry": ["src/index.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "plugins/socket-client": {
      "entry": ["src/index.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "plugins/bun-ws-server": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "plugins/bun-ws-client": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/wmux": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/wmux-client": {
      "entry": ["src/index.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignore": [
    "node_modules/**",
    "dist/**",
    "lib/**"
  ],
  "ignoreDependencies": [
    "@changesets/cli"
  ]
}
